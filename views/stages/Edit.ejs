<%- include('../../public/layouts/header') %>

<div class="container py-5">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">Modifier la recherche #<%= recherche.id_recherche %></h3>
        </div>
        <div class="card-body">
            <form action="/stages/edit/<%= recherche.id_recherche %>" method="POST">
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Élève</label>
                    <select class="form-select" name="id_eleve" required>
                        <% eleves.forEach(eleve => { %>
                            <option value="<%= eleve.id_eleve %>" 
                                <%= eleve.id_eleve === recherche.id_eleve ? 'selected' : '' %>>
                                <%= eleve.nom %> <%= eleve.prenom %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Entreprise</label>
                    <input type="text" name="entreprise_contactee" class="form-control" 
                           value="<%= recherche.entreprise_contactee %>" required>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Lettres envoyées</label>
                        <input type="number" name="nb_lettres_envoyees" class="form-control" 
                               value="<%= recherche.nb_lettres_envoyees %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Réponses reçues</label>
                        <input type="number" name="nb_lettres_recues" class="form-control" 
                               value="<%= recherche.nb_lettres_recues %>">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Date d'entretien</label>
                    <input type="date" name="date_entretien" class="form-control" 
                           value="<%= recherche.date_entretien ? recherche.date_entretien.toISOString().split('T')[0] : '' %>">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Notes</label>
                    <textarea name="resultat" class="form-control" rows="3"><%= recherche.resultat %></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/stages/view" class="btn btn-secondary">Annuler</a>
                    <button type="submit" class="btn btn-warning">Mettre à jour</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../../public/layouts/footer') %>