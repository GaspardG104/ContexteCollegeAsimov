<%- include('../../public/layouts/header') %>

    <link rel="stylesheet" href="/css/style_stage.css">

    <body class="container mt-4">
        <h2>Tableau de bord des stages</h2>
        <div class="container py-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="display-6">📋 Suivi Professionnel</h2>
                <a href="/stages/create" class="btn btn-primary shadow-sm">+ Déclarer une recherche</a>
            </div>

            <div class="card p-3">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Élève</th>
                            <th>Entreprise</th>
                            <th class="text-center">Intensité</th>
                            <th>Convention</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% stages.forEach(r=> { %>
                            <tr class="<%= r.alerte ? 'table-danger-custom' : '' %>">
                                <td>
                                    <strong>
                                        <%= r.nom.toUpperCase() %>
                                    </strong>
                                    <%= r.prenom %>
                                        <div class="small text-muted">ID: <%= r.id_eleve %>
                                        </div>
                                </td>
                                <td>
                                    <%= r.entreprise_contactee %>
                                </td>
                                <td class="text-center">
                                    <span
                                        class="badge rounded-pill <%= r.alerte ? 'bg-danger' : 'bg-info text-dark' %> badge-recherche">
                                        <%= r.nb_lettres_envoyees %> envois
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary status-badge">
                                        <%= r.etat_convention || 'Vierge' %>
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a href="/stages/edit/<%= r.id_recherche %>"
                                            class="btn btn-outline-warning btn-sm">
                                            <i class="fa-solid fa-pen"></i> Modifier</a>
                                        <a href="/stages/pdf/<%= r.id_recherche %>"
                                            class="btn btn-outline-danger btn-sm">
                                            <i class="fa-solid fa-file-pdf"></i> PDF
                                        </a>
                                        <a href="/stages/delete/<%= r.id_recherche %>"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Supprimer cette recherche ?')">
                                            <i class="fa-solid fa-trash-can"></i> Supprimer
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <%- include('../../public/layouts/footer') %>