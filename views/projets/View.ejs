<%- include('../../public/layouts/header') %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-rocket-takeoff me-2"></i>Projets de l'établissement</h2>
        <a href="/projets/create" class="btn btn-success">
            + Nouveau Projet
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nom du Projet</th>
                        <th>Responsable</th>
                        <th>Période</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (projets.length > 0) { %>
                        <% projets.forEach(p => { %>
                            <tr>
                                <td><span class="text-muted">#<%= p.id_projet %></span></td>
                                <td><strong><%= p.libelle %></strong></td>
                                <td>
                                    <% if (p.nom_resp) { %>
                                        <i class="bi bi-person-badge me-1"></i><%= p.nom_resp %> <%= p.prenom %>
                                    <% } else { %>
                                        <span class="text-muted italic">Aucun</span>
                                    <% } %>
                                </td>
                                <td>
                                    <small>
                                        Du <%= p.date_debut ? new Date(p.date_debut).toLocaleDateString() : '?' %> 
                                        au <%= p.date_fin ? new Date(p.date_fin).toLocaleDateString() : 'en cours' %>
                                    </small>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a href="/projets/edit/<%= p.id_projet %>" class="btn btn-sm btn-outline-primary">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <button onclick="confirmDelete('<%= p.id_projet %>')" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Aucun projet enregistré pour le moment.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="/js/projets.js"></script>

<%- include('../../public/layouts/footer') %>