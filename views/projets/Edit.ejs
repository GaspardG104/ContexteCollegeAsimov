<<%- include('../../public/layouts/header') %>

<div class="container py-5">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">Déclarer un nouveau projet</h3>
        </div>
        <div class="card-body">
            <form action="/projets/create" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Nom du projet</label>
                    <input type="text" name="libelle" class="form-control" placeholder="Ex: Club Échecs" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Élève responsable</label>
                    <select class="form-select" name="id_eleve_responsable">
                        <option value="">-- Choisir un élève --</option>
                        <% eleves.forEach(eleve => { %>
                            <option value="<%= eleve.id_eleve %>"><%= eleve.nom %> <%= eleve.prenom %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de début</label>
                        <input type="date" name="date_debut" class="form-control">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date de fin prévue</label>
                        <input type="date" name="date_fin" class="form-control">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Description</label>
                    <textarea name="description" class="form-control" rows="3" placeholder="Objectifs du projet..."></textarea>
                </div>

                <div class="d-flex justify-content-between pt-3">
                    <a href="/projets/view" class="btn btn-secondary">Annuler</a>
                    <button type="submit" class="btn btn-success">Créer le projet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../../public/layouts/footer') %>